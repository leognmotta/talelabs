{
  "openapi": "3.0.0",
  "info": {
    "title": "TaleLabs API",
    "version": "0.1.0",
    "description": "Organization-first TaleLabs API"
  },
  "servers": [
    {
      "url": "http://localhost:5174",
      "description": "Local API"
    }
  ],
  "components": {
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "example": true
          }
        },
        "required": [
          "ok"
        ]
      },
      "MeResponse": {
        "type": "object",
        "properties": {
          "activeOrganizationId": {
            "type": "string",
            "example": "org_123"
          },
          "isSystemAdmin": {
            "type": "boolean",
            "example": false
          },
          "session": {
            "type": "object",
            "properties": {
              "createdAt": {
                "type": "string",
                "format": "date-time"
              },
              "expiresAt": {
                "type": "string",
                "format": "date-time"
              },
              "id": {
                "type": "string"
              }
            },
            "required": [
              "createdAt",
              "expiresAt",
              "id"
            ]
          },
          "user": {
            "type": "object",
            "properties": {
              "email": {
                "type": "string",
                "format": "email",
                "example": "mail@leomotta.me"
              },
              "id": {
                "type": "string",
                "example": "user_123"
              },
              "locale": {
                "type": "string",
                "nullable": true,
                "enum": [
                  "en",
                  "pt-BR",
                  "pt-PT",
                  "es",
                  "fr",
                  "de",
                  "it",
                  "nl",
                  "pl",
                  "ro",
                  null
                ],
                "example": "pt-BR"
              },
              "name": {
                "type": "string",
                "example": "Leonardo Motta"
              }
            },
            "required": [
              "email",
              "id",
              "locale",
              "name"
            ]
          }
        },
        "required": [
          "activeOrganizationId",
          "isSystemAdmin",
          "session",
          "user"
        ]
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "example": "validation_error"
              },
              "message": {
                "type": "string",
                "example": "The request could not be validated."
              },
              "details": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/ErrorDetail"
                }
              }
            },
            "required": [
              "code",
              "message"
            ]
          }
        },
        "required": [
          "error"
        ]
      },
      "ErrorDetail": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "field": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "params": {
            "type": "object",
            "additionalProperties": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "number"
                },
                {
                  "type": "boolean"
                }
              ]
            }
          }
        },
        "required": [
          "code",
          "field",
          "message"
        ]
      },
      "SetPasswordResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "boolean",
            "enum": [
              true
            ]
          }
        },
        "required": [
          "status"
        ]
      },
      "SetPasswordRequest": {
        "type": "object",
        "properties": {
          "newPassword": {
            "type": "string",
            "minLength": 8,
            "example": "correct horse battery staple"
          }
        },
        "required": [
          "newPassword"
        ]
      },
      "ListOrganizationsResponse": {
        "type": "object",
        "properties": {
          "organizations": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Organization"
            }
          }
        },
        "required": [
          "organizations"
        ]
      },
      "Organization": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "org_123"
          },
          "name": {
            "type": "string",
            "example": "Acme Inc"
          },
          "slug": {
            "type": "string",
            "example": "acme-inc"
          },
          "logo": {
            "type": "string",
            "nullable": true,
            "example": null
          },
          "role": {
            "type": "string",
            "nullable": true,
            "example": "admin"
          },
          "isSystemAdminAccess": {
            "type": "boolean",
            "example": false
          }
        },
        "required": [
          "id",
          "name",
          "slug",
          "logo",
          "role",
          "isSystemAdminAccess"
        ]
      },
      "ActivateOrganizationResponse": {
        "type": "object",
        "properties": {
          "organization": {
            "$ref": "#/components/schemas/Organization"
          }
        },
        "required": [
          "organization"
        ]
      },
      "UpdateOrganizationResponse": {
        "type": "object",
        "properties": {
          "organization": {
            "$ref": "#/components/schemas/Organization"
          }
        },
        "required": [
          "organization"
        ]
      },
      "UpdateOrganizationRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "example": "Acme Inc"
          },
          "slug": {
            "type": "string",
            "minLength": 1,
            "example": "acme-inc"
          },
          "logo": {
            "type": "string",
            "nullable": true,
            "format": "uri",
            "example": null
          }
        },
        "required": [
          "name",
          "slug"
        ]
      },
      "ListInvitationsResponse": {
        "type": "object",
        "properties": {
          "invitations": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Invitation"
            }
          }
        },
        "required": [
          "invitations"
        ]
      },
      "Invitation": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "invite_123"
          },
          "organizationId": {
            "type": "string",
            "example": "org_123"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "new-user@example.com"
          },
          "role": {
            "type": "string",
            "enum": [
              "admin",
              "member"
            ],
            "example": "member"
          },
          "status": {
            "type": "string",
            "example": "pending"
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "inviteUrl": {
            "type": "string",
            "format": "uri",
            "example": "http://localhost:5173/accept-invitation?token=invite_123"
          }
        },
        "required": [
          "id",
          "organizationId",
          "email",
          "role",
          "status",
          "expiresAt",
          "createdAt",
          "inviteUrl"
        ]
      },
      "ListOrganizationMembersResponse": {
        "type": "object",
        "properties": {
          "members": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrganizationMember"
            }
          }
        },
        "required": [
          "members"
        ]
      },
      "OrganizationMember": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "member_123"
          },
          "organizationId": {
            "type": "string",
            "example": "org_123"
          },
          "userId": {
            "type": "string",
            "example": "user_123"
          },
          "name": {
            "type": "string",
            "example": "Ada Lovelace"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "ada@example.com"
          },
          "role": {
            "type": "string",
            "enum": [
              "admin",
              "member"
            ],
            "example": "member"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "organizationId",
          "userId",
          "name",
          "email",
          "role",
          "createdAt"
        ]
      },
      "CreateInvitationResponse": {
        "type": "object",
        "properties": {
          "invitation": {
            "$ref": "#/components/schemas/Invitation"
          }
        },
        "required": [
          "invitation"
        ]
      },
      "CreateInvitationRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "new-user@example.com"
          },
          "role": {
            "type": "string",
            "enum": [
              "admin",
              "member"
            ],
            "default": "member",
            "example": "member"
          },
          "resend": {
            "type": "boolean",
            "example": false
          }
        },
        "required": [
          "email"
        ]
      },
      "RevokeInvitationResponse": {
        "type": "object",
        "properties": {
          "invitation": {
            "$ref": "#/components/schemas/Invitation"
          }
        },
        "required": [
          "invitation"
        ]
      },
      "ListProjectsResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Project"
            }
          },
          "nextCursor": {
            "type": "string",
            "nullable": true
          }
        },
        "required": [
          "data",
          "nextCursor"
        ]
      },
      "Project": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "createdBy": {
            "type": "string",
            "nullable": true
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "name",
          "description",
          "createdBy",
          "createdAt",
          "updatedAt"
        ]
      },
      "CreateProjectRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 160
          },
          "description": {
            "type": "string",
            "maxLength": 4000
          }
        },
        "required": [
          "name"
        ]
      },
      "UpdateProjectRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 160
          },
          "description": {
            "type": "string",
            "nullable": true,
            "maxLength": 4000
          }
        }
      },
      "UpdateAccountPreferencesResponse": {
        "type": "object",
        "properties": {
          "locale": {
            "type": "string",
            "nullable": true,
            "enum": [
              "en",
              "pt-BR",
              "pt-PT",
              "es",
              "fr",
              "de",
              "it",
              "nl",
              "pl",
              "ro",
              null
            ],
            "example": "pt-BR"
          }
        },
        "required": [
          "locale"
        ]
      },
      "UpdateAccountPreferencesRequest": {
        "type": "object",
        "properties": {
          "locale": {
            "type": "string",
            "nullable": true,
            "enum": [
              "en",
              "pt-BR",
              "pt-PT",
              "es",
              "fr",
              "de",
              "it",
              "nl",
              "pl",
              "ro",
              null
            ],
            "example": "pt-BR"
          }
        },
        "required": [
          "locale"
        ]
      }
    },
    "parameters": {}
  },
  "paths": {
    "/db/health": {
      "get": {
        "operationId": "getDbHealth",
        "tags": [
          "System"
        ],
        "responses": {
          "200": {
            "description": "Database connection health",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/me": {
      "get": {
        "operationId": "getMe",
        "tags": [
          "Account"
        ],
        "responses": {
          "200": {
            "description": "Authenticated user and active organization session",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MeResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Active organization required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/me/password": {
      "post": {
        "operationId": "setAccountPassword",
        "tags": [
          "Account"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SetPasswordRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Password was created for the authenticated account",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SetPasswordResponse"
                }
              }
            }
          },
          "400": {
            "description": "Password could not be created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/organizations": {
      "get": {
        "operationId": "listOrganizations",
        "tags": [
          "Organizations"
        ],
        "responses": {
          "200": {
            "description": "Organizations available to the current user",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListOrganizationsResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/organizations/{organizationId}/activate": {
      "post": {
        "operationId": "activateOrganization",
        "tags": [
          "Organizations"
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "example": "org_123"
            },
            "required": true,
            "name": "organizationId",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Activated organization session",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ActivateOrganizationResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Organization access required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/organizations/{organizationId}": {
      "patch": {
        "operationId": "updateOrganization",
        "tags": [
          "Organizations"
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "example": "org_123"
            },
            "required": true,
            "name": "organizationId",
            "in": "path"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateOrganizationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated organization metadata",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UpdateOrganizationResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Organization admin required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Organization not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Organization slug already exists",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/organizations/{organizationId}/invitations": {
      "get": {
        "operationId": "listOrganizationInvitations",
        "tags": [
          "Invitations"
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "example": "org_123"
            },
            "required": true,
            "name": "organizationId",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Organization invitations",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListInvitationsResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Organization admin required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createOrganizationInvitation",
        "tags": [
          "Invitations"
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "example": "org_123"
            },
            "required": true,
            "name": "organizationId",
            "in": "path"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateInvitationRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Generated invitation token and URL",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateInvitationResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Organization admin required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Pending invitation already exists",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "502": {
            "description": "Invitation email could not be sent",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/organizations/{organizationId}/members": {
      "get": {
        "operationId": "listOrganizationMembers",
        "tags": [
          "Organizations"
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "example": "org_123"
            },
            "required": true,
            "name": "organizationId",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Organization members",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListOrganizationMembersResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Organization admin required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/organizations/{organizationId}/invitations/{invitationId}": {
      "delete": {
        "operationId": "revokeOrganizationInvitation",
        "tags": [
          "Invitations"
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "example": "org_123"
            },
            "required": true,
            "name": "organizationId",
            "in": "path"
          },
          {
            "schema": {
              "type": "string",
              "example": "invite_123"
            },
            "required": true,
            "name": "invitationId",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Revoked organization invitation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RevokeInvitationResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Organization admin required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Pending invitation not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/projects": {
