{
  "name": "@talelabs/trigger",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "check-types": "tsc --noEmit",
    "dev": "trigger dev --config ../../trigger.config.ts --env-file ../../.env --skip-rules-install",
    "dev:build": "tsc --watch --preserveWatchOutput",
    "predev": "node scripts/assert-dev-env.mjs --worker"
  },
  "dependencies": {
    "@talelabs/db": "*",
    "@talelabs/storage": "*",
    "@trigger.dev/sdk": "4.5.3",
    "dotenv": "^17.2.3",
    "sharp": "^0.34.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "5.9.2"
  }
}
