{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "rootDir": ".",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "resolveJsonModule": true,
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist",
    "verbatimModuleSyntax": true,
    "skipLibCheck": true
  },
  "include": ["catalog.json", "models", "scripts", "src"],
  "exclude": ["node_modules", "dist"]
}
