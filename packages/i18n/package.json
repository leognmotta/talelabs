{
  "name": "@talelabs/i18n",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./catalogs": {
      "types": "./src/catalogs.ts",
      "default": "./dist/catalogs.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "check-types": "tsc --noEmit && tsc --project tsconfig.tests.json",
    "dev:build": "tsc --watch --preserveWatchOutput",
    "i18n:check": "node scripts/check-catalogs.mjs",
    "lint": "eslint .",
    "test": "tsx --test src/*.test.ts"
  },
  "dependencies": {
    "i18next": "^26.1.0"
  },
  "devDependencies": {
    "i18next-cli": "^1.65.0",
    "tsx": "^4.21.0",
    "typescript": "5.9.2"
  }
}
