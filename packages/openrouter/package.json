{
  "name": "@talelabs/openrouter",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc && node dist/routes/verify.js",
    "check-types": "tsc --noEmit",
    "dev:build": "tsc --watch --preserveWatchOutput",
    "routes:check": "tsc && node dist/routes/verify.js"
  },
  "dependencies": {
    "@openrouter/sdk": "^0.13.36",
    "@talelabs/flows": "*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "5.9.2"
  }
}
