{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalPassThroughEnv": [
    "APP_SECRET",
    "BETTER_AUTH_URL",
    "DASHBOARD_URL",
    "OPENROUTER_API_KEY",
    "POSTGRES_URL",
    "R2_ACCESS_KEY_ID",
    "R2_ACCOUNT_ID",
    "R2_SECRET_ACCESS_KEY",
    "RESEND_API_KEY",
    "RESEND_FROM_EMAIL",
    "STRIPE_PUBLISHABLE_KEY",
    "STRIPE_SECRET_KEY",
    "TEST_POSTGRES_URL",
    "TRIGGER_PROJECT_REF",
    "TRIGGER_SECRET_KEY",
    "TRIGGER_DEPLOYMENT_VERSION"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**", "src/gen/**", "openapi.json"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "test": {
      "dependsOn": ["^test"],
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:build": {
      "cache": false,
      "persistent": true
    }
  }
}
