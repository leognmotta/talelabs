{
  "name": "api",
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch --include '../../packages/{assets,auth,cache,db,email,flows,i18n,models-catalog,providers,storage,trigger}/dist/**/*.js' src/index.ts",
    "dev:e2e": "NODE_ENV=development tsx watch src/index.ts",
    "verify:m5-runs": "npm run run:check -w @talelabs/flows",
    "verify:browser-planner-snapshot": "tsx scripts/verify-browser-planner-snapshot-matrix.ts",
    "verify:provider-availability": "tsx scripts/verify-provider-availability.ts",
    "build": "tsc -p tsconfig.build.json",
    "check-types": "tsc --noEmit",
    "start": "node dist/index.js",
    "test": "tsx --test src/tests/*.test.ts",
    "test:integration": "REQUIRE_TEST_POSTGRES_URL=1 tsx --test src/tests/*.integration.test.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.4.0",
    "@paralleldrive/cuid2": "^3.3.0",
    "@talelabs/assets": "*",
    "@talelabs/auth": "*",
    "@talelabs/cache": "*",
    "@talelabs/db": "*",
    "@talelabs/flows": "*",
    "@talelabs/i18n": "^0.0.0",
    "@talelabs/models-catalog": "*",
    "@talelabs/providers": "*",
    "@talelabs/storage": "*",
    "@talelabs/trigger": "*",
    "hono": "^4.12.29",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.7.1",
    "typescript": "5.9.2"
  }
}
