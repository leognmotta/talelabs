{
  "name": "talelabs",
  "private": true,
  "packageManager": "npm@10.9.0",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "turbo run build",
    "db:migrate": "npm run migrate -w @talelabs/db",
    "dev": "turbo run dev",
    "kubb:mcp": "kubb mcp",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "prebuild": "npm run sdk:generate",
    "precheck-types": "npm run sdk:generate",
    "predev": "npm run sdk:generate",
    "sdk:generate": "npm run generate -w @talelabs/sdk",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@eslint-react/eslint-plugin": "^5.7.9",
    "@kubb/cli": "^4.37.7",
    "@kubb/core": "^4.37.7",
    "@kubb/mcp": "^4.37.7",
    "@kubb/plugin-client": "^4.37.7",
    "@kubb/plugin-oas": "^4.37.7",
    "@kubb/plugin-react-query": "^4.37.7",
    "@kubb/plugin-ts": "^4.37.7",
    "@kubb/plugin-zod": "^4.37.7",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "ajv": "^8.20.0",
    "eslint": "^10.4.0",
    "eslint-plugin-better-tailwindcss": "^4.5.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "prettier": "^3.7.4",
    "turbo": "^2.9.14",
    "typescript": "5.9.2"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
