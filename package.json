{
  "name": "connecto",
  "private": true,
  "packageManager": "npm@10.9.0",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "turbo run build",
    "db:migrate": "npm run migrate -w @connecto/db",
    "dev": "turbo run dev",
    "kubb:mcp": "kubb mcp",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@eslint-react/eslint-plugin": "^5.7.9",
    "@kubb/cli": "^5.0.0-beta.13",
    "@kubb/mcp": "^5.0.0-beta.13",
    "eslint": "^10.4.0",
    "eslint-plugin-better-tailwindcss": "^4.5.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "prettier": "^3.7.4",
    "turbo": "^2.9.14",
    "typescript": "5.9.2"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
