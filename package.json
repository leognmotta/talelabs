{
  "name": "talelabs",
  "private": true,
  "packageManager": "npm@10.9.0",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "build": "turbo run build",
    "db:migrate": "npm run migrate -w @talelabs/db",
    "dev": "turbo run dev --concurrency=15",
    "dev:prepare": "turbo run build --filter='api^...'",
    "kubb:mcp": "kubb mcp",
    "lint": "eslint . --ignore-pattern 'docs/**'",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "predev": "npm run dev:prepare && npm run sdk:generate && node packages/trigger/scripts/assert-dev-env.mjs",
    "sdk:generate": "npm run generate -w @talelabs/sdk",
    "i18n:check": "npm run i18n:check -w @talelabs/i18n",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "test:integration": "npm run test:integration -w api",
    "tsdoc:check": "node scripts/check-tsdoc-coverage.mjs",
    "trigger:deploy:check": "trigger deploy --env prod --dry-run --config trigger.config.ts",
    "trigger:deploy:prod": "trigger deploy --env prod --config trigger.config.ts",
    "trigger:dev": "turbo run dev --filter=@talelabs/trigger"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@eslint-react/eslint-plugin": "^5.7.9",
    "@kubb/cli": "^4.37.7",
    "@kubb/core": "^4.37.7",
    "@kubb/mcp": "^4.37.7",
    "@kubb/plugin-client": "^4.37.7",
    "@kubb/plugin-oas": "^4.37.7",
    "@kubb/plugin-react-query": "^4.37.7",
    "@kubb/plugin-ts": "^4.37.7",
    "@kubb/plugin-zod": "^4.37.7",
    "@trigger.dev/build": "4.5.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "ajv": "^8.20.0",
    "eslint": "^10.4.0",
    "eslint-plugin-better-tailwindcss": "^4.5.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "prettier": "^3.7.4",
    "trigger.dev": "4.5.3",
    "turbo": "^2.9.14",
    "typescript": "5.9.2"
  },
  "overrides": {
    "ws": "^8.21.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
